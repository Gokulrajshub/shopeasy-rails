<nav class="d-flex align-items-center justify-content-between px-4 py-3 bg-dark">
  <div class="text-white fs-5 fw-medium">ShopEasy — Admin Panel</div>
  <div class="d-flex align-items-center gap-3">
    <span class="text-white-50 small">Welcome, <%= current_user.name %></span>
    <%= button_to "Logout", logout_path, method: :delete, class: "btn btn-outline-danger btn-sm" %>
  </div>
</nav>

<div class="container mt-4">
  <div class="row g-3 mb-4">
    <div class="col-md-4">
      <div class="card border-0 rounded-4 p-3 text-white" style="background:#E53935;">
        <p class="small mb-1 opacity-75">Total Users</p>
        <h2 class="fw-medium mb-0"><%= @total_users %></h2>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card border-0 rounded-4 p-3 text-white" style="background:#1565C0;">
        <p class="small mb-1 opacity-75">Total Products</p>
        <h2 class="fw-medium mb-0"><%= @total_products %></h2>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card border-0 rounded-4 p-3 text-white" style="background:#2E7D32;">
        <p class="small mb-1 opacity-75">Total Orders</p>
        <h2 class="fw-medium mb-0"><%= @total_orders %></h2>
      </div>
    </div>
  </div>

  <div class="d-flex gap-2 mb-4">
    <%= link_to "Add New Product", add_new_product_path, class: "btn btn-danger" %>
    <%= link_to "View All Products", products_path, class: "btn btn-outline-secondary" %>
    <%= link_to "View All Orders", admin_orders_path, class: "btn btn-outline-secondary" %>
  </div>

  <div class="card border rounded-4">
    <div class="card-body">
      <h5 class="fw-medium mb-3">Recent Orders</h5>
      <% if @recent_orders.any? %>
        <table class="table table-hover align-middle">
          <thead class="table-light">
            <tr>
              <th>Order ID</th>
              <th>Customer</th>
              <th>Amount</th>
              <th>Status</th>
              <th>Date</th>
            </tr>
          </thead>
          <tbody>
            <% @recent_orders.each do |order| %>
              <tr>
                <td><a href="<%= admin_orders_path %>">#<%= order.id %></a></td>
                <td><%= order.user.name %></td>
                <td>₹<%= order.total_amount %></td>
                <td>
                  <span class="badge <%= order.status == 'delivered' ? 'bg-success' : order.status == 'pending' ? 'bg-warning text-dark' : 'bg-secondary' %>">
                    <%= order.status&.capitalize %>
                  </span>
                </td>
                <td class="text-muted small"><%= order.created_at.strftime("%d %b %Y") %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="text-muted">No orders yet.</p>
      <% end %>
    </div>
  </div>
</div>