<nav class="d-flex align-items-center justify-content-between px-4 py-2 bg-danger">
  <div class="text-white fs-4 fw-medium">ShopEasy</div>
  <div class="d-flex align-items-center gap-3">
    <span class="text-white">Hi, <%= current_user.name %></span>
    <%= link_to cart_path, class: "btn btn-outline-light btn-sm" do %>
      <i class="fa-solid fa-cart-shopping"></i> Cart
    <% end %>
    <%= link_to user_home_path, class: "btn btn-outline-light btn-sm" do %>
      <i class="fa-solid fa-house"></i> Home
    <% end %>
    <%= button_to "Logout", logout_path, method: :delete, class: "btn btn-outline-light btn-sm" %>
  </div>
</nav>

<div class="p-4 page">
  <div class="accordion w-75 mx-auto" id="ordersAccordion">
    <% @orders.each do |order| %>
      <div class="accordion-item mb-2 border rounded-4 shadow-sm">
        <h4 class="accordion-header" id="heading<%=order.id%>">
          <button class= "accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse<%= order.id %>">
            <div class="d-flex justify-content-between w-100 me-3 align-items-center">
              <div>
                <h6 class="mb-1 fw-semibold">Order #<%= order.id%> </h6>
                <small class="text-muted"><%= order.created_at.strftime("%d %b %Y")%></small>
              </div>
              <div class="text-end">
                <span class="badge border border-warning text-warning px-2 py-1"><%= order.status%></span>
                <div class="small text-muted mt-1"> ₹<%= order.total_amount%> </div>
              </div>
            </div>
          </button>
        </h4>
        <div id="collapse<%= order.id%>" class="accordion-collapse collapse" data-bs-parent="#ordersAccordion">
          <div class="accordion-body">
            <div>
              <h6> Ordered Items </h6>
              <% order.order_items.each do |item|%>
              <div class="d-flex justify-content-between">
                <div><%= item.product.name %> x <%= item.quantity%></div>
                <div><%= item.price%> </div>
              </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>

<style>
  .page{
  background: #f5f5f5
  }
  .accordion-button{
    background: #fff;
  }
  .accordion-button:not(.collapsed){
    background: #fff;
    box-shadow: none;
  }
  .accordion-button:focus{
    box-shadow: none;
  }
  .accordion-item{
    border-radius: 12px;
    overflow: hidden;
  }
</style>