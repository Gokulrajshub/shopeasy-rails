<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Project Development" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/virtual-select-plugin@1/dist/virtual-select.min.css">
    <script src="https://cdn.jsdelivr.net/npm/virtual-select-plugin@1/dist/virtual-select.min.js"></script>
  </head>

  <body>
    <%= yield %>
    <% if flash[:success] %>
      <script>
        Swal.fire({
          title: 'Success!',
          text: '<%= j flash[:success] %>',
          icon: 'success',
          confirmButtonText: 'Cool'
        });
      </script>
    <% end %>

    <% if flash[:alert] %>
      <script>
        Swal.fire({
          title: 'Error!',
          text: '<%= j flash[:alert] %>',
          icon: 'error',
          confirmButtonText: 'Try Again'
        });
      </script>
    <% end %>

    <% if flash[:error] %>
      <script>
        Swal.fire({
          icon: 'error',
          title: 'Oops...',
          text: '<%= j flash[:error] %>',
        })
      </script>
    <% end %>
  </body>
</html>
