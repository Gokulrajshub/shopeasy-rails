<div class="login-container min-vh-100 d-flex align-items-center justify-content-center" style="background: linear-gradient(135deg, #FF7043, #E53935);">
  <div class="card shadow border-0 rounded-4" style="width:100%; max-width:450px">
    <div class="card-body p-5">
    
      <div class="text-center">
        <h3 class="fw-bold text-danger">ShopEasy</h3>
        <p class="text-muted">Welcome back! Please login to continue</p>
      </div>
 

  <%# model: nil nu kuduthurukkom, yen na session-ku database table kedaiyaathu %>
  <%= form_with url: login_path, local: true, class: "login-form" do |f| %>
    
    <div class="field mb-3">
      <%= f.label :email, class: "form-label fw-medium small" %>
      <%= f.email_field :email, placeholder: "Enter your email", required: true, class: "form-control" %>
    </div>

    <div class="field mb-3">
      <%= f.label :password, class: "form-label fw-medium small" %>
      <%= f.password_field :password, placeholder: "Enter your password", required: true, class: "form-control" %>
    </div>

    <div class="actions">
      <%= f.submit "Login", class: "btn btn-danger btn-login w-100" %>
    </div>

  <% end %>
  
  <div class="text-center mt-4">
    <p class="small text-muted mb-0">Don't have an account?</p>
    <%= link_to "Signup here", signup_path, class: "fw-medium" %>
  </div>
    </div>
  </div>
</div>