<div class="home-container">
  <nav class="px-4 py-2 bg-danger d-flex align-items-center justify-content-between">  
    <div class="text-white fs-4 fw-bolder">ShopEasy</div>
    <div>
       <%= link_to "Login", login_path, class: "btn btn-light btn-sm fw-medium" %>
       <%= link_to "Sign Up", signup_path, class: "btn btn-outline-light btn-sm" %>
    </div>
  </nav>

<div class="text-center text-white p-5" style="background: linear-gradient(135deg, #FF7043, #E53935);">
  <h1 class="fw-medium mb-2">Best Deals, Every Day!</h1>
  <p class="mb-4 opacity-75">Shop latest products at unbeatable prices. Free delivery above ₹499</p>
  <%= link_to "Shop Now →", login_path, class: "btn btn-light fw-medium px-4 py-2" %>
</div>

<div class="container my-4">
  <div class="row g-3">
    <div class="col-md-6">
      <div class="text-white rounded-3 p-4" style="background: #FF7043;">
        <h5 class="fw-medium">New Arrivals</h5>
        <p class="opacity-75 small">Check out this season's hottest products</p>
        <%= link_to "Explore →", login_path, class: "btn btn-outline-light btn-sm" %>
      </div>
    </div>
    <div class="col-md-6">
      <div class="text-white rounded-3 p-4" style="background: #1565C0;">
        <h5 class="fw-medium">Flash Sale — 50% Off</h5>
        <p class="opacity-75 small">Limited time offer on selected items</p>
        <%= link_to "Grab Now →", login_path, class: "btn btn-outline-light btn-sm" %>
      </div>
    </div>
  </div>
</div>

<div class="container mb-5">
  <h2 class="fw-medium mb-3 fs-5">Featured Products</h2>
  <div class="row row-cols-2 row-cols-md-4 g-3">
    <% if @products.any? %>
      <% @products.each do |product| %>
        <div class="col">
          <div class="card h-100 border shadow-sm">
            <div class="card-body text-center py-4 bg-light">
              <% if product.image.attached? %>
    <%= image_tag product.image, class: "img-fluid rounded", style: "height: 120px; object-fit: cover; width: 100%;" %>
  <% else %>
    <span style="font-size: 40px;">🛍️</span>
  <% end %>
            </div>
            <div class="card-footer bg-white border-0 px-3 pb-0">
              <p class="fw-medium mb-1 small"><%= product.name %></p>
              <p class="text-danger fw-medium mb-2">₹<%= product.price %></p>
            </div>
            <%= link_to "View", login_path, class: "btn btn-danger btn-sm w-100 rounded-0 rounded-bottom" %>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="col-12">
        <p class="text-muted">No products available yet. Check back soon!</p>
      </div>
    <% end %>
  </div>
</div>

<!-- FOOTER -->
<footer class="bg-dark text-white text-center py-3 small">
  © 2025 ShopEasy — All rights reserved
</footer>
</div>
