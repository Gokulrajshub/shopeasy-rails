<nav class="d-flex align-items-center justify-content-between px-4 py-2 bg-dark">
  <div class="text-white fs-4 fw-medium">ShopEasy — Admin Panel</div>
  <%= link_to "← Dashboard", admin_dashboard_path, class: "btn btn-outline-secondary btn-sm" %>
</nav>

<div class="page">
  <div class="container py-4">
    <h5 class="fw-medium mb-3">All Orders (<%= @orders.count %>)</h5>

    <% @orders.each do |order| %>
      <div class="card border rounded-4 mb-3">
        <div class="card-body d-flex align-items-center gap-3 border-bottom">
          <span class="fw-medium">#<%= order.id %></span>
          <span><%= order.user.name %></span>
          <div class="ms-auto d-flex align-items-center gap-5">
            <span>₹<%= order.total_amount %></span>
            <span class="text-muted small"><%= order.created_at.strftime("%d %b %Y") %></span>
            <% badge_style = order.status == 'delivered' ? 'border: 1.5px solid #2E7D32; color: #2E7D32;' : order.status == 'shipped' ? 'border: 1.5px solid #1565C0; color: #1565C0;' : 'border: 1.5px solid #E65100; color: #E65100;' %>
            <span class="badge bg-transparent fw-medium" style="<%= badge_style %>">
              <%= order.status&.capitalize %>
            </span>
          </div>
        </div>

        <div class="px-3 py-2 bg-light d-flex gap-2 flex-wrap">
          <% order.order_items.each do |item| %>
            <span class="badge bg-light text-dark border">
              <%= item.product.name %> x<%= item.quantity %>
            </span>
          <% end %>
        </div>

        <div class="px-3 py-2 d-flex justify-content-end gap-2">
          <%= form_with url: update_order_status_path(order), method: :patch, local: true, class: "d-flex gap-2 align-items-center" do |f| %>
            <%= f.select :status, ['Pending', 'Shipped', 'Delivered'], 
                { selected: order.status }, 
                class: "form form-select form-select-sm", style: "width: auto;" %>
            <%= f.submit "Update", class: "btn btn-danger btn-sm" %>
          <% end %>
        </div>

      </div>
    <% end %>
  </div>
</div>
<style >
  .page{
  background: #f5f5f5
  }
</style>